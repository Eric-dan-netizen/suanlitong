# ═══════════════════════════════════════════════════════
# 算力通 · 环境变量模板
# 复制为 .env 后填入真实值
# cp .env.example .env
# ═══════════════════════════════════════════════════════

# ── 应用 ──────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=sqlite:///./suanlitong.db

# ── 阿里云 ────────────────────────────────────────────
ALIYUN_ACCESS_KEY_ID=your-aliyun-key-id-here
ALIYUN_ACCESS_KEY_SECRET=your-aliyun-key-secret-here

# ── 华为云 ────────────────────────────────────────────
HUAWEI_ACCESS_KEY_ID=your-huawei-key-id-here
HUAWEI_ACCESS_KEY_SECRET=your-huawei-key-secret-here

# ── 腾讯云 ────────────────────────────────────────────
TENCENT_SECRET_ID=your-tencent-secret-id-here
TENCENT_SECRET_KEY=your-tencent-secret-key-here

# ── 设备 Agent 心跳 ───────────────────────────────────
HEARTBEAT_HOST=127.0.0.1
HEARTBEAT_PORT=9999

# ── Redis（本地开发可选） ─────────────────────────────
REDIS_URL=redis://localhost:6379/0
