# Auto-detect text files and normalize line endings
* text=auto

# Markdown
*.md text diff=markdown

# Python
*.py text diff=python

# PPTX (binary)
*.pptx binary

# PDF (binary)
*.pdf binary

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg text

# Data files
*.csv text
*.json text
*.yaml text
*.yml text
*.toml text

# Shell scripts
*.sh text eol=lf

# Lock files (generated)
*.lock binary
